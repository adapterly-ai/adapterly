      "tool_type": "read",
      "parameters_schema": {
        "type": "object",
        "properties": {
          "project_id": {
            "type": "string",
            "description": "Project ID"
          }
        },
        "required": [
          "project_id"
        ]
      }
    },
    {
      "slug": "schedules_get",
      "name": "get",
      "description": "Get schedule details",
      "method": "GET",
      "path": "/schedules/{schedule_id}",
      "tool_type": "read",
      "parameters_schema": {
        "type": "object",
