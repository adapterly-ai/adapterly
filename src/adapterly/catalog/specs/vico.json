      "tool_type": "read",
      "parameters_schema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "slug": "projects_get",
      "name": "get",
      "description": "Get project details",
      "method": "GET",
      "path": "/projects/{project_id}",
      "tool_type": "read",
      "parameters_schema": {
        "type": "object",
        "properties": {
          "project_id": {
            "type": "string",
            "description": "Project ID"
          }
        },
        "required": [
          "project_id"
        ]
      }
    },
    {
      "slug": "schedules_list",
