{
  "slug": "sokopro",
  "name": "SokoPro",
  "description": "SokoPro - Finnish project bank and document management system. Widely used in Finnish construction for document distribution, version control, and project communication.",
  "category": "storage",
  "base_url": "https://api.sokopro.fi/v1",
  "auth_config": {
    "type": "bearer",
    "header": "Authorization",
    "prefix": "Bearer"
  },
  "variables": {
    "api_url": "https://api.sokopro.fi"
  },
  "tools": [
    {
      "slug": "projects_list",
      "name": "list",
      "description": "List all projects",
      "method": "GET",
      "path": "/projects",
      "tool_type": "read",
      "parameters_schema": {
        "type": "object",
        "properties": {}
      }
    },
    {
      "slug": "projects_get",
      "name": "get",
      "description": "Get project details",
      "method": "GET",
      "path": "/projects/{project_id}",
      "tool_type": "read",
      "parameters_schema": {
        "type": "object",
        "properties": {
          "project_id": {
            "type": "string",
            "description": "Project ID"
          }
        },
        "required": [
          "project_id"
        ]
      }
    },
    {
      "slug": "folders_list",
      "name": "list",
      "description": "List project folders",
      "method": "GET",
      "path": "/projects/{project_id}/folders",
      "tool_type": "read",
      "parameters_schema": {
        "type": "object",
        "properties": {
          "project_id": {
            "type": "string",
            "description": "Project ID"
          }
        },
        "required": [
          "project_id"
        ]
      }
    },
    {
      "slug": "folders_get_contents",
      "name": "get_contents",
      "description": "Get folder contents",
      "method": "GET",
      "path": "/folders/{folder_id}/contents",
      "tool_type": "read",
      "parameters_schema": {
        "type": "object",
        "properties": {
          "folder_id": {
            "type": "string",
            "description": "Folder ID"
          }
        },
        "required": [
          "folder_id"
        ]
      }
    },
    {
      "slug": "documents_list",
      "name": "list",
      "description": "List documents",
      "method": "GET",
      "path": "/projects/{project_id}/documents",
      "tool_type": "read",
      "parameters_schema": {
        "type": "object",
        "properties": {
          "project_id": {
            "type": "string",
            "description": "Project ID"
          },
          "folder_id": {
            "type": "string",
            "description": "Filter by folder"
          },
          "modified_since": {
            "type": "string",
            "format": "date-time",
            "description": "Filter by modification date"
          }
        },
        "required": [
          "project_id"
        ]
      }
    },
    {
      "slug": "documents_get",
      "name": "get",
      "description": "Get document details",
      "method": "GET",
      "path": "/documents/{document_id}",
      "tool_type": "read",
      "parameters_schema": {
        "type": "object",
        "properties": {
          "document_id": {
            "type": "string",
            "description": "Document ID"
          }
        },
        "required": [
          "document_id"
        ]
      }
    },
    {
      "slug": "documents_get_versions",
      "name": "get_versions",
      "description": "Get document version history",
      "method": "GET",
      "path": "/documents/{document_id}/versions",
      "tool_type": "read",
      "parameters_schema": {
        "type": "object",
        "properties": {
          "document_id": {
            "type": "string",
            "description": "Document ID"
          }
        },
        "required": [
          "document_id"
        ]
      }
    },
    {
      "slug": "documents_download",
      "name": "download",
      "description": "Download document file",
      "method": "GET",
      "path": "/documents/{document_id}/download",
      "tool_type": "read",
      "parameters_schema": {
        "type": "object",
        "properties": {
          "document_id": {
            "type": "string",
            "description": "Document ID"
          },
          "version": {
            "type": "integer",
            "description": "Version number (latest if omitted)"
          }
        },
        "required": [
          "document_id"
        ]
      }
    },
    {
      "slug": "distributions_list",
      "name": "list",
      "description": "List distribution lists",
      "method": "GET",
      "path": "/projects/{project_id}/distributions",
      "tool_type": "read",
      "parameters_schema": {
        "type": "object",
        "properties": {
          "project_id": {
            "type": "string",
            "description": "Project ID"
          }
        },
        "required": [
          "project_id"
        ]
      }
    },
    {
      "slug": "distributions_send",
      "name": "send",
      "description": "Send documents to distribution list",
      "method": "POST",
      "path": "/distributions/{distribution_id}/send",
      "tool_type": "write",
      "parameters_schema": {
        "type": "object",
        "properties": {
          "distribution_id": {
            "type": "string",
            "description": "Distribution list ID"
          },
          "document_ids": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "Document IDs to send"
          },
          "message": {
            "type": "string",
            "description": "Optional message"
          }
        },
        "required": [
          "distribution_id",
          "document_ids"
        ]
      }
    },
    {
      "slug": "comments_list",
      "name": "list",
      "description": "List document comments",
      "method": "GET",
      "path": "/documents/{document_id}/comments",
      "tool_type": "read",
      "parameters_schema": {
        "type": "object",
        "properties": {
          "document_id": {
            "type": "string",
            "description": "Document ID"
          }
        },
        "required": [
          "document_id"
        ]
      }
    },
    {
      "slug": "comments_create",
      "name": "create",
      "description": "Add comment to document",
      "method": "POST",
      "path": "/documents/{document_id}/comments",
      "tool_type": "write",
      "parameters_schema": {
        "type": "object",
        "properties": {
          "document_id": {
            "type": "string",
            "description": "Document ID"
          },
          "text": {
            "type": "string",
            "description": "Comment text"
          }
        },
        "required": [
          "document_id",
          "text"
        ]
      }
    }
  ]
}
